import java.util.*;

class Book {
    int id;
    String name;

    Book(int id, String name) {
        this.id = id;
        this.name = name;
    }
}

class Library {
    private ArrayList<Book> books = new ArrayList<>();
    private Stack<Book> issuedBooks = new Stack<>();
    private Queue<Book> requestQueue = new LinkedList<>();
    private HashMap<Integer, Book> bookMap = new HashMap<>();

    public void addBook(int id, String name) {
        Book book = new Book(id, name);
        books.add(book);
        bookMap.put(id, book);
        System.out.println("Book Added");
    }

    public void displayBooks() {
        if (books.isEmpty()) {
            System.out.println("No Books Available");
            return;
        }

        for (Book b : books) {
            System.out.println(b.id + " -> " + b.name);
        }
    }

    public void searchBook(int id) {
        if (bookMap.containsKey(id)) {
            System.out.println("Found: " + bookMap.get(id).name);
        } else {
            System.out.println("Not Found");
        }
    }

    public void issueBook(int id) {
        if (bookMap.containsKey(id)) {
            Book b = bookMap.get(id);
            issuedBooks.push(b);
            books.remove(b);
            bookMap.remove(id);
            System.out.println("Book Issued");
        } else {
            System.out.println("Book Not Available");
        }
    }

    public void returnBook() {
        if (!issuedBooks.isEmpty()) {
            Book b = issuedBooks.pop();
            books.add(b);
            bookMap.put(b.id, b);
            System.out.println("Book Returned");
        } else {
            System.out.println("No Issued Books");
        }
    }

    public void requestBook(int id, String name) {
        requestQueue.add(new Book(id, name));
        System.out.println("Request Added");
    }

    public void processRequests() {
        while (!requestQueue.isEmpty()) {
            Book b = requestQueue.poll();
            System.out.println("Processing Request: " + b.name);
        }
    }
}

public class LibraryManagement {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Library lib = new Library();

        while (true) {
            System.out.println("\nLibrary Management System");
            System.out.println("1. Add Book");
            System.out.println("2. Display Books");
            System.out.println("3. Search Book");
            System.out.println("4. Issue Book");
            System.out.println("5. Return Book");
            System.out.println("6. Request Book");
            System.out.println("7. Process Requests");
            System.out.println("8. Exit");
            System.out.print("Enter Choice: ");

            int choice = sc.nextInt();

            switch (choice) {
                case 1:
                    System.out.print("Enter ID: ");
                    int id = sc.nextInt();
                    sc.nextLine();
                    System.out.print("Enter Name: ");
                    String name = sc.nextLine();
                    lib.addBook(id, name);
                    break;

                case 2:
                    lib.displayBooks();
                    break;

                case 3:
                    System.out.print("Enter ID: ");
                    lib.searchBook(sc.nextInt());
                    break;

                case 4:
                    System.out.print("Enter ID: ");
                    lib.issueBook(sc.nextInt());
                    break;

                case 5:
                    lib.returnBook();
                    break;

                case 6:
                    System.out.print("Enter ID: ");
                    int rid = sc.nextInt();
                    sc.nextLine();
                    System.out.print("Enter Name: ");
                    String rname = sc.nextLine();
                    lib.requestBook(rid, rname);
                    break;

                case 7:
                    lib.processRequests();
                    break;

                case 8:
                    System.exit(0);

                default:
                    System.out.println("Invalid Choice");
            }
        }
    }
}
